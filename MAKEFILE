# ==============================================================================
# VARIÁVEIS DO PROJETO
# ==============================================================================
# Altere 'app.py' para o nome do seu arquivo principal caso seja diferente (ex: main.py)
FLASK_APP = app.py

.PHONY: run clean-cache db-update help

# ==============================================================================
# COMANDOS DISPONÍVEIS
# ==============================================================================

# Comando padrão caso digite apenas 'make'
help:
	@echo "Comandos disponíveis:"
	@echo "  make run         - Inicia o servidor Flask em modo de desenvolvimento/debug"
	@echo "  make clean-cache - Limpa todos os arquivos temporários e caches do Python"
	@echo "  make db-update   - Inicializa ou atualiza as tabelas do banco de dados (SQLite)"

# 1. Comando para rodar o projeto
run:
	@echo "🚀 Iniciando o servidor Flask no modo de desenvolvimento..."
	flask --app $(FLASK_APP) run --debug

# 2. Comando para limpar o cache do Python
clean:
	@echo "🧹 Limpando arquivos de cache (.pyc e __pycache__)..."
	@find . -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
	@find . -type f -name "*.pyc" -delete 2>/dev/null || true
	@echo "✔ Cache limpo com sucesso!"

# 3. Comando para atualizar/inicializar o banco de dados
db:
	@echo "💾 Atualizando/Inicializando tabelas do banco de dados (database.db)..."
	@python3 -c "\
from models.character import CharacterModel; \
from models.mesa import MesaModel; \
CharacterModel.init_db(); \
MesaModel.init_db();"
	@echo "✔ Banco de dados atualizado com sucesso!"